#!/usr/bin/env bash
# Regenerates bun.nix from bun.lock via bun2nix whenever bun.lock or
# package.json are part of the commit, and stages the regenerated file
# so it's included in that same commit.
#
# This file *is* the hook -- there is no copy installed elsewhere.
# `nix develop` points this worktree's core.hooksPath at .githooks/
# (see flake.nix), so editing this file takes effect on your next commit.
set -euo pipefail

if ! git diff --cached --name-only -z | grep -qzE '^(bun\.lock|package\.json)$'; then
  exit 0
fi

if ! command -v bun2nix >/dev/null 2>&1; then
  echo "pre-commit: bun.lock/package.json changed but 'bun2nix' is not on PATH." >&2
  echo "pre-commit: run this inside 'nix develop' so bun2nix is available, then commit again." >&2
  exit 1
fi

bun2nix -o bun.nix

if ! git diff --quiet -- bun.nix; then
  git add bun.nix
  echo "pre-commit: regenerated bun.nix from bun.lock and staged it"
fi
